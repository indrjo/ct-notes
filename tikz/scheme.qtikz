
\begin{tikzpicture}[shorten <=1pt, shorten >=1pt, every node/.style={fill=gray!50!white,circle}]
\node (A) at (-2,0) {};
\node (B) at (0,1) {};
\node (C) at (2,0) {};
\node (D) at (0,-1) {};
\draw [->] (A) to[bend left]  node[auto]{} (B);
\draw [->] (A) to[bend right] node[auto,swap]{} (B);
\draw [->] (B) to[bend left]  node[auto]{} (C);
\draw [->] (D) to[bend right] node[auto,swap]{} (B);
\end{tikzpicture}
